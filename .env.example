# LLM provider keys
# Preference order: Mistral -> Grok/Groq -> Gemini
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_API_BASE=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-large-latest
XAI_API_KEY=your-xai-api-key
XAI_API_BASE=https://api.x.ai/v1
XAI_MODEL=grok-2-1212
# Optional dedicated Groq key. The current fallback also recognizes a gsk_ key
# supplied through XAI_API_KEY.
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
# Application server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CACHE_DIR=.cache
# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=stock_intelligence
# Authentication
# Replace this with a long random value before running outside local development.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7